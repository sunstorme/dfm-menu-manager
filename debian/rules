#!/usr/bin/make -f

# Uncomment to enable verbose build
# export DH_VERBOSE=1

# Enable hardening
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# CMake build flags
DEB_CMAKE_NORMAL_FLAGS = -DCMAKE_INSTALL_PREFIX=/usr \
                         -DCMAKE_BUILD_TYPE=Release \
                         -DCMAKE_SKIP_RPATH=ON \
                         -DQT_VERSION_MAJOR=6

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- $(DEB_CMAKE_NORMAL_FLAGS)

override_dh_missing:
	dh_missing --fail-missing

override_dh_install:
	dh_install
	# Install icons
	install -D -m 644 debian/dfm-menu-manager.svg \
	    debian/dfm-menu-manager/usr/share/icons/hicolor/scalable/apps/dfm-menu-manager.svg || true
	# Install desktop file
	install -D -m 644 debian/dfm-menu-manager.desktop \
	    debian/dfm-menu-manager/usr/share/applications/dfm-menu-manager.desktop || true
